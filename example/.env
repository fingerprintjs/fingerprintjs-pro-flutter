# https://dev.fingerprint.com/docs/quick-start-guide#2-get-your-api-key
# API_KEY=

# https://dev.fingerprint.com/docs/regions
# REGION=

# https://dev.fingerprint.com/docs/install-the-javascript-agent#configuring-the-agent
# SCRIPT_URL_PATTERN=

# https://dev.fingerprint.com/docs/install-the-javascript-agent#configuring-the-agent
# ENDPOINT=

# Set to true only for automated native tests to avoid location permission dialogs.
# Normal manual runs collect location data by default.
# DISABLE_LOCATION_COLLECTION=false

# Set to true for automated E2E smoke tests to run only the core checks.
# Normal manual runs keep the full example check suite.
# E2E_SMOKE_TEST=false
